{
  "name": "@migrate-sdk/commercetools",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [],
  "exports": {
    ".": "./src/index.ts",
    "./destination": "./src/destination/index.ts",
    "./migration-store": "./src/migration-store/index.ts",
    "./source": "./src/source/index.ts",
    "./testing": "./src/testing/index.ts",
    "./internal/*": null,
    "./*/internal/*": null
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "example:product-catalog-store": "tsx examples/product-catalog-store-migration.ts",
    "example:product-catalog-store:live": "tsx examples/product-catalog-store-migration.live.ts",
    "example:products": "tsx examples/product-destination.ts",
    "prepare": "effect-language-service patch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.75",
    "migrate-sdk": "0.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.75",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "effect": "4.0.0-beta.75",
    "migrate-sdk": "workspace:*",
    "tsx": "^4.22.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@commercetools/platform-sdk": "^8.27.0",
    "@commercetools/sdk-client-v2": "^3.5.0"
  }
}
