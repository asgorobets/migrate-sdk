{
  "name": "@migrate-sdk/commercetools",
  "version": "0.4.0",
  "type": "module",
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/asgorobets/migrate-sdk",
    "directory": "packages/commercetools"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "docs/**/*.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./destination": {
      "types": "./dist/destination/index.d.ts",
      "bun": "./src/destination/index.ts",
      "source": "./src/destination/index.ts",
      "import": "./dist/destination/index.js"
    },
    "./migration-store": {
      "types": "./dist/migration-store/index.d.ts",
      "bun": "./src/migration-store/index.ts",
      "source": "./src/migration-store/index.ts",
      "import": "./dist/migration-store/index.js"
    },
    "./source": {
      "types": "./dist/source/index.d.ts",
      "bun": "./src/source/index.ts",
      "source": "./src/source/index.ts",
      "import": "./dist/source/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "bun": "./src/testing/index.ts",
      "source": "./src/testing/index.ts",
      "import": "./dist/testing/index.js"
    },
    "./internal/*": null,
    "./*/internal/*": null
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/clean-build-output.mjs dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ../../scripts/rewrite-declaration-extensions.mjs dist",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "example:business-units:live": "pnpm run build && migrate run --config examples/migrate.config.ts business-unit-static-field",
    "example:product-catalog-store": "pnpm run build && tsx examples/product-catalog-store-migration.ts",
    "example:product-catalog-store:live": "pnpm run build && tsx examples/product-catalog-store-migration.live.ts",
    "example:products": "pnpm run build && tsx examples/product-destination.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "effect": "catalog:",
    "migrate-sdk": "workspace:>=0.1.0 <1.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.1",
    "effect": "catalog:",
    "migrate-sdk": "workspace:*",
    "tsx": "^4.22.4",
    "@typescript/native": "npm:typescript@7.0.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@commercetools/platform-sdk": "^8.27.0",
    "@commercetools/sdk-client-v2": "^3.5.0"
  }
}
