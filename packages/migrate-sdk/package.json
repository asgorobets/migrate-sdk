{
  "name": "migrate-sdk",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [],
  "bin": {
    "migrate": "./bin/migrate-sdk.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli/index.ts",
    "./cli/testing": "./src/cli/testing.ts",
    "./core": "./src/core.ts",
    "./destinations/in-memory": "./src/destinations/in-memory/index.ts",
    "./destinations/in-memory/testing": "./src/destinations/in-memory/testing.ts",
    "./internal/*": null,
    "./runtime": "./src/runtime/index.ts",
    "./sources/csv": "./src/sources/csv/index.ts",
    "./sources/document": "./src/sources/document/index.ts",
    "./sources/in-memory": "./src/sources/in-memory/index.ts",
    "./sources/sql": "./src/sources/sql/index.ts",
    "./stores/file": "./src/stores/file/index.ts",
    "./stores/in-memory": "./src/stores/in-memory/index.ts",
    "./testing": "./src/testing.ts",
    "./*/internal/*": null
  },
  "scripts": {
    "cli": "node ./bin/migrate-sdk.mjs",
    "dev": "tsx examples/dev.ts",
    "dev:circular-stubs": "tsx examples/dev.ts circular-stubs",
    "dev:api-source": "tsx examples/dev.ts api-source",
    "dev:document-source": "tsx examples/dev.ts document-source",
    "dev:file-store": "tsx examples/dev.ts file-store",
    "dev:nested-article": "tsx examples/dev.ts nested-article",
    "prepare": "effect-language-service patch",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/sql-sqlite-node": "4.0.0-beta.75",
    "@effect/vitest": "4.0.0-beta.75",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.1",
    "@types/papaparse": "^5.5.2",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.75",
    "effect": "4.0.0-beta.75",
    "papaparse": "^5.5.3",
    "tsx": "^4.22.4"
  }
}
