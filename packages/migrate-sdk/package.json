{
  "name": "migrate-sdk",
  "version": "0.4.0",
  "type": "module",
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/asgorobets/migrate-sdk",
    "directory": "packages/migrate-sdk"
  },
  "bin": {
    "migrate": "./dist/cli/bin.js"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "bun": "./src/cli/index.ts",
      "source": "./src/cli/index.ts",
      "import": "./dist/cli/index.js"
    },
    "./cli/testing": {
      "types": "./dist/cli/testing.d.ts",
      "bun": "./src/cli/testing.ts",
      "source": "./src/cli/testing.ts",
      "import": "./dist/cli/testing.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "bun": "./src/core.ts",
      "source": "./src/core.ts",
      "import": "./dist/core.js"
    },
    "./destinations/in-memory": {
      "types": "./dist/destinations/in-memory/index.d.ts",
      "bun": "./src/destinations/in-memory/index.ts",
      "source": "./src/destinations/in-memory/index.ts",
      "import": "./dist/destinations/in-memory/index.js"
    },
    "./destinations/in-memory/testing": {
      "types": "./dist/destinations/in-memory/testing.d.ts",
      "bun": "./src/destinations/in-memory/testing.ts",
      "source": "./src/destinations/in-memory/testing.ts",
      "import": "./dist/destinations/in-memory/testing.js"
    },
    "./internal/*": null,
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "bun": "./src/runtime/index.ts",
      "source": "./src/runtime/index.ts",
      "import": "./dist/runtime/index.js"
    },
    "./sources/csv": {
      "types": "./dist/sources/csv/index.d.ts",
      "bun": "./src/sources/csv/index.ts",
      "source": "./src/sources/csv/index.ts",
      "import": "./dist/sources/csv/index.js"
    },
    "./sources/document": {
      "types": "./dist/sources/document/index.d.ts",
      "bun": "./src/sources/document/index.ts",
      "source": "./src/sources/document/index.ts",
      "import": "./dist/sources/document/index.js"
    },
    "./sources/in-memory": {
      "types": "./dist/sources/in-memory/index.d.ts",
      "bun": "./src/sources/in-memory/index.ts",
      "source": "./src/sources/in-memory/index.ts",
      "import": "./dist/sources/in-memory/index.js"
    },
    "./sources/sql": {
      "types": "./dist/sources/sql/index.d.ts",
      "bun": "./src/sources/sql/index.ts",
      "source": "./src/sources/sql/index.ts",
      "import": "./dist/sources/sql/index.js"
    },
    "./stores/file": {
      "types": "./dist/stores/file/index.d.ts",
      "bun": "./src/stores/file/index.ts",
      "source": "./src/stores/file/index.ts",
      "import": "./dist/stores/file/index.js"
    },
    "./stores/in-memory": {
      "types": "./dist/stores/in-memory/index.d.ts",
      "bun": "./src/stores/in-memory/index.ts",
      "source": "./src/stores/in-memory/index.ts",
      "import": "./dist/stores/in-memory/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "bun": "./src/testing.ts",
      "source": "./src/testing.ts",
      "import": "./dist/testing.js"
    },
    "./*/internal/*": null
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "cli": "node ./bin/migrate-sdk.mjs",
    "dev": "pnpm run build && tsx examples/dev.ts",
    "dev:circular-stubs": "pnpm run build && tsx examples/dev.ts circular-stubs",
    "dev:api-source": "pnpm run build && tsx examples/dev.ts api-source",
    "dev:document-source": "pnpm run build && tsx examples/dev.ts document-source",
    "dev:file-store": "pnpm run build && tsx examples/dev.ts file-store",
    "dev:nested-article": "pnpm run build && tsx examples/dev.ts nested-article",
    "build": "node ../../scripts/clean-build-output.mjs dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ../../scripts/rewrite-declaration-extensions.mjs dist",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/sql-sqlite-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.1",
    "@types/papaparse": "^5.5.2",
    "@typescript/native": "npm:typescript@7.0.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "papaparse": "^5.5.3",
    "tsx": "^4.22.4"
  }
}
