{
  "name": "migrate-sdk",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [],
  "exports": {
    ".": "./src/index.ts",
    "./destinations/in-memory": "./src/destinations/in-memory/index.ts",
    "./internal/*": null,
    "./sources/csv": "./src/sources/csv/index.ts",
    "./sources/in-memory": "./src/sources/in-memory/index.ts",
    "./stores/file": "./src/stores/file/index.ts",
    "./stores/in-memory": "./src/stores/in-memory/index.ts",
    "./*/internal/*": null
  },
  "scripts": {
    "dev": "tsx examples/dev.ts",
    "dev:circular-stubs": "tsx examples/dev.ts circular-stubs",
    "dev:api-source": "tsx examples/dev.ts api-source",
    "dev:file-store": "tsx examples/dev.ts file-store",
    "dev:nested-article": "tsx examples/dev.ts nested-article",
    "prepare": "effect-language-service patch",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.75",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.22.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.75",
    "effect": "4.0.0-beta.75",
    "papaparse": "^5.5.3"
  }
}
