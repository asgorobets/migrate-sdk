{
  "name": "@migrate-sdk/workflow-sdk",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [],
  "exports": {
    ".": "./src/index.ts",
    "./steps": "./src/steps.ts",
    "./workflow": "./src/workflow.ts",
    "./internal/*": null,
    "./*/internal/*": null
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "prepare": "effect-language-service patch",
    "test": "vitest run",
    "test:workflow": "vitest run --config vitest.workflow.config.ts",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.75",
    "migrate-sdk": "0.0.0",
    "workflow": "^4.5.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.75",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.1",
    "@workflow/vitest": "4.0.11",
    "effect": "4.0.0-beta.75",
    "migrate-sdk": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  }
}
