{
  "name": "@migrate-sdk/workflow-sdk",
  "version": "0.4.0",
  "type": "module",
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/asgorobets/migrate-sdk",
    "directory": "packages/workflow-sdk"
  },
  "files": [
    "src/*.ts",
    "!src/*.test.ts",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/*.js",
    "dist/*.js.map",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./steps": {
      "types": "./dist/steps.d.ts",
      "bun": "./src/steps.ts",
      "source": "./src/steps.ts",
      "import": "./dist/steps.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "bun": "./src/workflow.ts",
      "source": "./src/workflow.ts",
      "import": "./dist/workflow.js"
    },
    "./internal/*": null,
    "./*/internal/*": null
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/clean-build-output.mjs dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ../../scripts/rewrite-declaration-extensions.mjs dist",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:workflow": "vitest run --config vitest.workflow.config.ts",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "effect": "catalog:",
    "migrate-sdk": "workspace:>=0.1.0 <1.0.0",
    "workflow": "^4.5.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.1",
    "@workflow/vitest": "4.0.11",
    "effect": "catalog:",
    "migrate-sdk": "workspace:*",
    "@typescript/native": "npm:typescript@7.0.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vitest": "^4.1.8"
  }
}
